    "steps": [
      {
        "order": 1,
        "text": "Char the halved onion and ginger under a grill or open flame until slightly blackened, about 5 minutes."
      },
      {
        "order": 2,
        "text": "Rinse beef bones and brisket under cold water. Place bones and brisket in a large pot and cover with 4 liters of cold water."
      },
      {
        "order": 3,
        "text": "Bring to a boil over high heat. Once boiling, discard the water and rinse bones and pot to remove impurities."
      },
      {
        "order": 4,
        "text": "Return bones and brisket to the pot. Add charred onion, ginger, star anise, cinnamon sticks, cloves, cardamom pod, rock sugar, and salt."
      },
      {
        "order": 5,
        "text": "Fill pot with 4 liters of fresh water. Bring to a boil, then reduce to a gentle simmer and cook uncovered for 3 hours, skimming foam occasionally."
      },
      {
        "order": 6,
        "text": "After 3 hours, remove brisket and set aside to cool. Strain the broth through a fine sieve or cheesecloth into a clean pot."
      },
      {
        "order": 7,
        "text": "Slice the brisket thinly once cooled. Add fish sauce to the broth and adjust seasoning as needed."
      },
      {
        "order": 8,
        "text": "Prepare rice noodles according to package instructions, usually soaking or briefly boiling, then drain."
      },
      {
        "order": 9,
        "text": "Divide noodles into serving bowls. Top with sliced brisket and chopped spring onions."
      },
      {
        "order": 10,
        "text": "Ladle hot broth over noodles and beef to warm the meat and soften noodles."
      },
      {
        "order": 11,
        "text": "Serve immediately with fresh bean sprouts, thai basil, cilantro, lime wedges, and sliced fresh chili on the side for garnish."
      }
