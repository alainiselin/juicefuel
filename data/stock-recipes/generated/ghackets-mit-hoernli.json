    "steps": [
      {
        "order": 1,
        "text": "Heat butter in a large pan over medium heat. Add chopped onion, carrot, and celery and sauté until softened, about 5 minutes."
      },
      {
        "order": 2,
        "text": "Add minced beef to the pan, breaking it up with a spoon. Cook until browned all over, about 8 minutes."
      },
      {
        "order": 3,
        "text": "Sprinkle flour over the meat and vegetables, stir well and cook for 1-2 minutes to remove raw flour taste."
      },
      {
        "order": 4,
        "text": "Gradually add beef broth while stirring to avoid lumps. Stir in tomato paste and add bay leaf."
      },
      {
        "order": 5,
        "text": "Reduce heat to low and simmer uncovered for 25-30 minutes until sauce thickens. Season with salt and pepper to taste."
      },
      {
        "order": 6,
        "text": "Meanwhile, bring a large pot of salted water to a boil. Cook elbow pasta according to package instructions until al dente. Drain well."
      },
      {
